# Kopyalayın ve .env olarak kaydedin
# PAYMENT_PROVIDER: stripe veya paytr
PAYMENT_PROVIDER=stripe

# Stripe bilgileri
STRIPE_SECRET_KEY=sk_test_...
STRIPE_SUCCESS_URL=http://localhost:5173/?status=success
STRIPE_CANCEL_URL=http://localhost:5173/?status=cancel

# PayTR bilgileri (sadece paytr kullanırken)
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_USER_ID=
PAYTR_MERCHANT_SALT=
PAYTR_SUCCESS_URL=http://localhost:5173/?status=success
PAYTR_FAIL_URL=http://localhost:5173/?status=fail
PAYTR_TEST_MODE=true

FRONTEND_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:3000
